###############################################################################
# OS / Editor noise
###############################################################################
**/.DS_Store
**/.AppleDouble
**/.LSOverride
**/Thumbs.db

###############################################################################
# Editor / IDE
###############################################################################
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*.orig

###############################################################################
# Python / Ansible
###############################################################################
.venv/
**/__pycache__/
**/*.pyc
**/.ansible/
.rumdl_cache/

###############################################################################
# Repo-local caches / generated artifacts
###############################################################################
.repomix/
**/.cache*
**/.helm_ls_cache/
**/logbuch/
**/reports/
**/artifacts/
**/_build/
**/build/
**/build-scan/
**/target/
**/crash.log
**/crash.*.log

###############################################################################
# Kubernetes / Helm
###############################################################################
**/helm-v3*
apps/**/charts/

**/tmpcharts-*
#apps/**/Chart.lock

###############################################################################
# Terraform (CRITICAL)
###############################################################################
**/.terraform/
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfstate.*.backup
**/*.tfstate.*

# tfvars: ignore all, allow only defaults
**/*.tfvars
!**/defaults.auto.tfvars
**/secrets.auto.tfvars

###############################################################################
# Environment / runtime configuration (CRITICAL)
###############################################################################
config.yaml
!ansible/roles/adguard/tasks/config.yaml
ansible/op.env
terraform/op.env
**/.env
**/.env.*
**/*.env
**/*.envrc

###############################################################################
# Kubernetes credentials (CRITICAL)
###############################################################################
**/kubeconfig
**/kubeconfig.*
**/*.kubeconfig

###############################################################################
# SSH / PKI / private keys (CRITICAL)
###############################################################################
**/*id_rsa*
**/*id_ed25519*
**/*.key
**/*.p12
**/*.pfx
**/*privkey*.pem
**/*private*.pem
**/tls.key

###############################################################################
# Certificates & helper cert artifacts
# (repo policy: no private cert material in Git)
###############################################################################
**/certs/

###############################################################################
# SealedSecrets safety
###############################################################################
**/*-unsealed.yaml
**/*unsealed*.yaml

###############################################################################
# Archives / exports / backups
###############################################################################
**/*.tgz
**/*.tar.gz
**/*.tar
**/*.zip
**/*.7z
**/*.bak
**/backups/
**/*.dump
**/*.sql
**/*.sqlite
**/.*tgz

###############################################################################
# Documentation archives (non-authoritative)
###############################################################################
docs/archive/
docs/not-git/

###############################################################################
# Local development context (not for repo)
###############################################################################
memory-bank/
.github/agents/
.github/*.chatmode.md
AGENTS.md
WARP.md
tools/patching/
apps/cluster/secrets-cluster/kubernetes/kubernetes-dhi-pat.yaml
###############################################################################
# Go binaries (generated artifacts - built in CI/local)
###############################################################################
tools/ci/infra-guard

###############################################################################
# Explicit historical ignores (kept intentionally)
###############################################################################
cluster/bootstrap/**/rendered.yaml
tools/patching/images
tools/patching/docs
tools/patching/build-scan
tools/pvecsictl
*.pub
docs/diaries/archived
.sisyphus/
