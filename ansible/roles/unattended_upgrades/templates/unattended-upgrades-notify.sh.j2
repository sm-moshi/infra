#!/usr/bin/env bash
# {{ ansible_managed }}
set -euo pipefail

HOSTNAME="{{ ansible_facts['hostname'] }}"
ENVIRONMENT="{{ unattended_upgrades_environment }}"
WEBHOOK_URL="{{ unattended_upgrades_webhook_url }}"
LOG_DIR="/var/log/unattended-upgrades"

# Safety: if no webhook configured, exit quietly
if [[ -z "${WEBHOOK_URL}" ]]; then
  exit 0
fi

# Find the most recent log file
LATEST_LOG=$(find "${LOG_DIR}" -name "unattended-upgrades-dpkg_*.log" -mtime -1 2>/dev/null | sort -r | head -1 || true)

if [[ -z "${LATEST_LOG}" ]]; then
  # No recent upgrade activity
  exit 0
fi

# Extract summary from log
UPGRADED=$(grep -c "^Unpacking\|^Setting up" "${LATEST_LOG}" 2>/dev/null || echo "0")
ERRORS=$(grep -ci "error\|failed\|dpkg.*error" "${LATEST_LOG}" 2>/dev/null || echo "0")

if [[ "${UPGRADED}" == "0" && "${ERRORS}" == "0" ]]; then
  exit 0
fi

# Check if reboot is required
REBOOT_REQUIRED="No"
if [[ -f /var/run/reboot-required ]]; then
  REBOOT_REQUIRED="Yes"
fi

BODY_TEXT=$(printf "📦 Unattended Upgrades Report\nHost: %s\nEnvironment: %s\nPackages processed: %s\nErrors: %s\nReboot required: %s" \
  "${HOSTNAME}" "${ENVIRONMENT}" "${UPGRADED}" "${ERRORS}" "${REBOOT_REQUIRED}")

curl -sS -X POST "${WEBHOOK_URL}" \
  -H "Content-Type: application/json" \
  -d "$(jq -Rn --arg content "${BODY_TEXT}" '{content: $content}')"
