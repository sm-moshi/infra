server: "{{ k3s_cluster_server_url }}"
token: "{{ k3s_cluster_token }}"
resolv-conf: /etc/rancher/k3s/kubelet-resolv.conf
node-name: "{{ k3s_node_name | default(inventory_hostname) }}"
{% set node_ip = k3s_node_ip | default(ansible_host) %}
{% set external_ips = k3s_node_external_ip | default([node_ip]) %}
{% if k3s_node_ipv6 | default("") %}
node-ip: "{{ node_ip }},{{ k3s_node_ipv6 }}"
{% else %}
node-ip: "{{ node_ip }}"
{% endif %}
node-external-ip:
{% for ip in external_ips %}
  - "{{ ip }}"
{% endfor %}
{% if k3s_flannel_iface | default("") %}
flannel-iface: "{{ k3s_flannel_iface }}"
{% endif %}
{% if k3s_node_labels | default([]) | length > 0 %}
node-label:
{% for label in k3s_node_labels %}
  - "{{ label }}"
{% endfor %}
{% endif %}
{% if k3s_node_taints | default([]) | length > 0 %}
node-taint:
{% for taint in k3s_node_taints %}
  - "{{ taint }}"
{% endfor %}
{% endif %}
{% set kubelet_args = (k3s_kubelet_args_common | default([])) + (k3s_kubelet_args | default([])) %}
{% if (k3s_allow_swap | default(false)) or (kubelet_args | length > 0) %}
kubelet-arg:
{% if k3s_allow_swap | default(false) %}
  - "fail-swap-on=false"
{% endif %}
{% for arg in kubelet_args %}
  - "{{ arg }}"
{% endfor %}
{% endif %}
