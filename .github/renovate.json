{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":preserveSemverRanges",
    ":enablePreCommit",
    "local>sm-moshi/infra//.github/renovate/helm-wrapper-groups"
  ],
  "platformAutomerge": false,
  "dependencyDashboard": true,
  "dependencyDashboardApproval": true,
  "dependencyDashboardAutoclose": true,
  "timezone": "Europe/Berlin",
  "schedule": [
    "at any time"
  ],
  "prHourlyLimit": 12,
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "pinDigests": false,
  "enabledManagers": [
    "terraform",
    "helmv3",
    "helm-values",
    "dockerfile",
    "github-actions",
    "ansible",
    "ansible-galaxy",
    "kustomize",
    "mise",
    "pre-commit",
    "argocd"
  ],
  "labels": [
    "dependencies"
  ],
  "ignorePaths": [
    "docs/archive/**",
    "tools/patching/base/**",
    "tools/patching/images/**",
    "apps/*/docker/**",
    "apps/**/charts/**"
  ],
  "ignoreDeps": [
    "harbor.m0sh1.cc/ghcr/renovatebot/renovate"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "argocd": {
    "managerFilePatterns": [
      "/argocd/.+\\.yaml$/"
    ]
  },
  "helmv3": {
    "managerFilePatterns": [
      "/apps/cluster/.+/Chart\\.yaml$/",
      "/apps/user/.+/Chart\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/apps/cluster/.+/values\\.yaml$/",
      "/apps/user/.+/values\\.yaml$/"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/cluster/.+/kustomization\\.yaml$/",
      "/apps/.+/kustomization\\.yaml$/"
    ]
  },
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": false
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": false
    },
    {
      "matchManagers": [
        "terraform"
      ],
      "labels": [
        "dependencies",
        "terraform"
      ]
    },
    {
      "matchManagers": [
        "helmv3",
        "helm-values"
      ],
      "separateMajorMinor": false,
      "labels": [
        "dependencies",
        "helm"
      ]
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "labels": [
        "dependencies",
        "docker"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "labels": [
        "dependencies",
        "ci"
      ]
    },
    {
      "matchManagers": [
        "pre-commit",
        "github-actions",
        "ansible",
        "ansible-galaxy",
        "mise",
        "terraform"
      ],
      "groupName": "non-helm tooling",
      "addLabels": [
        "devops"
      ]
    }
  ]
}
